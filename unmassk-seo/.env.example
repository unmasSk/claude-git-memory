# unmassk-seo MCP API Keys
# Copy this file to .env and fill in your API keys.
# Only configure the services you have accounts for — the rest will be skipped.

# DataForSEO (https://dataforseo.com)
DATAFORSEO_USERNAME=
DATAFORSEO_PASSWORD=

# Ahrefs (https://ahrefs.com/api)
AHREFS_API_KEY=

# Semrush (https://www.semrush.com/api)
SEMRUSH_API_KEY=

# Google Search Console (path to service account JSON)
GSC_CREDENTIALS_PATH=

# PageSpeed Insights (https://developers.google.com/speed/docs/insights/v5/get-started)
PAGESPEED_API_KEY=
